# Data vendors. Leave a key blank to disable the matching provider; the pipeline
# then degrades (sample data / fallback constants) and records the degradation
# in run_metadata.json. Never commit a populated .env file.

# Financial Modeling Prep: universe, fundamentals, estimates, quotes.
FMP_API_KEY=

# Polygon.io: daily bars / liquidity. Optional; FMP quotes are used as fallback.
POLYGON_API_KEY=

# FRED: risk-free rate (DGS10). Optional; a configured fallback rate is used otherwise.
FRED_API_KEY=

# SEC EDGAR requires a descriptive User-Agent with contact info, e.g.
# "WeeklyUSStock research bot you@example.com".
SEC_USER_AGENT=

# Override the configured data source (sample | fmp | auto).
WEEKLY_US_STOCK_DATA_SOURCE=

# Override the output directory for run artifacts.
WEEKLY_US_STOCK_OUTPUT_DIR=
